# Bytecode
__pycache__/
*.py[codz]
*.pyo
*.pyc

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
pythonenv/
*.virtualenv

# Package builds
*.egg
*.egg-info/
*.egg-info
dist/
build/
eggs/
sdist/
*.whl
wheels/
develop-eggs/
parts/
pip-wheel-metadata/
pip-log.txt
pip-delete-this-directory.txt

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Linters
.ruff_cache/
.pylint.d/
.flake8

# ============================================================
# 7. Python — test & coverage
# ============================================================
.pytest_cache/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
htmlcov/
.tox/
.nox/
nosetests.xml
test-output/

# Hypothesis (property-based testing)
.hypothesis/

# ============================================================
# 8. AI / ML — model weights, checkpoints, embeddings
# ============================================================

# Model checkpoints (use Git LFS or external storage)
*.pth
*.pt
*.ckpt
*.gguf
*.h5
*.hdf5
*.pb
*.pbtxt
*.onnx
*.safetensors
*.bin         # generic model binaries
*.caffemodel
*.dlc

# Pickle — model states, embeddings
*.pkl
*.pickle

# Embeddings / vector stores (generated, not source)
*.index
*.faiss
*.parquet
*.snapshot.*

# ONNX Runtime
*.ort

# CoreML
*.mlmodel
*.mlpackage

# NCNN / TNN / MNN
*.param
!**/src/**/*.param

# Generated data (should be produced by scripts, not committed)
vector_data.dump
vector_data/
models/
python-agent/models/
*.vectors.npy
*.embeddings
python-agent/grpo_output/
python-agent/sft_output/

# ============================================================
# 9. Docker
# ============================================================

# Docker build context — explicitly ignore
docker-compose.override.yml
.dockerignore_local

# Don't ignore Dockerfiles (they are source)
# docker-compose.yml is source

# ============================================================
# 10. Docs, Data & Uploads (runtime / agent-generated)
# ============================================================
docs/*
!docs/deployment.md
!docs/experiment_log.md
!docs/graph_multi_agent_architecture.md
uploads/
.agents/
.tests/
user_uploads/
sandbox-temp/
temp/
tmp/
*.tmp
*.temp

# ============================================================
# 11. Logs
# ============================================================
*.log
logs/
*.log.*
!**/logback-spring.xml       # keep logging config templates

# ============================================================
# 12. Backups & Archives
# ============================================================
*.bak
*.backup
*.old
*.orig
*.zip
*.tar.gz
*.tgz
*.rar
*.7z

# ============================================================
# 13. Misc
# ============================================================

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb_checkpoints
.Jupyter/

# macOS resource forks
*.rsrc

# Temporary editor files
*~

# ============================================================
# 14. Explicitly NOT ignored (negate patterns)
# ============================================================

# migrations/ — database migrations — MUST be tracked
# contracts/ — API schemas — MUST be tracked
# init.sql — database seed — MUST be tracked
# All Dockerfiles — source files
# Knowledge base JSON files — source data
