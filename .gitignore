# ============================================================
# 智学引擎 (Smart Engine) — Git Ignore Rules
# 协作项目，保证跨平台、多 IDE、PR 干净
# ============================================================

# ============================================================
# 1. Environment & Secrets
# ============================================================
.env
.env.*
.env.*.local
*.env.local
*.env.development.local
*.env.test.local
*.env.production.local


# Keep templates
!.env.example
!.env.template

# ============================================================
# 2. OS Files (Windows / macOS / Linux)
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
*.orig

# Docker persistent data (generated at runtime)
data/

# ============================================================
# 3. IDE / Editor (multi-contributor safe)
# ============================================================

# JetBrains (IntelliJ / PyCharm / WebStorm / GoLand)
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code — keep shared workspace config
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix

# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
.vs/
[Bb]uild/
Generated\ Files/

# Eclipse / STS
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
.apt_generated
.loadpath
.springBeans

# NetBeans
nbproject/
nbbuild/
nbdist/
.nb-gradle/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
# Swap files (note: [._] prefix prevents matching .sql/.sml etc.)
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-z][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
# Backup / undo
*~
[._]*.un~
# Session
Session.vim
Sessionx.vim
.netrwhist

# Emacs
*#
\#*\#
.\#*

# ============================================================
# 4. Frontend — Node.js / React / Vite
# ============================================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Package manager logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

# Vite cache
frontend/.vite/

# TypeScript incremental build
*.tsbuildinfo

# ============================================================
# 5. Java — Spring Boot / Maven / Gradle
# ============================================================

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
gradle/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
gradle-app.setting
*.gradle.kts
build/
!src/**/build/
!gradle-wrapper.jar
buildSrc/build/

