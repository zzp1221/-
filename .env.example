# Copy this file to .env before running docker compose.
# Never commit real .env files.

TZ=Asia/Shanghai

# Host ports. Data services are bound to 127.0.0.1 in docker-compose.yml.
FRONTEND_PORT=80
APP_PORT=8081
PY_AGENT_PORT=8000
POSTGRES_PORT=5432
MONGO_PORT=27017
REDIS_PORT=6379

# Core storage.
POSTGRES_DB=zhixue
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
MONGO_DB=zhixue

# Java control plane.
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:5174
APP_JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes
PYTHON_AGENT_INTERNAL_TOKEN=replace-with-a-random-shared-internal-token

# Python Agent runtime.
PY_AGENT_WORKERS=2
CONTROL_PLANE_BASE_URL=http://app:8081
ENABLE_LOCAL_JUDGE=false

# LLM provider. The default configuration uses an OpenAI-compatible endpoint.
AI_OPENAI_COMPATIBLE_API_KEY=replace-with-openai-compatible-api-key
AI_OPENAI_COMPATIBLE_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# Embedding key. DASHSCOPE_API_KEY is accepted as an alias by the Python Agent.
EMBEDDING_API_KEY=replace-with-embedding-api-key
DASHSCOPE_API_KEY=

# Optional MiMo-specific settings.
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Optional web search.
TAVILY_API_KEY=

# Optional local subjective judge overlay.
# Start with:
# docker compose -f docker-compose.yml -f docker-compose.local-judge.yml up -d --build
INSTALL_LOCAL_JUDGE=true
LOCAL_JUDGE_MODEL_DIR=./models
LOCAL_JUDGE_MODEL_PATH=/app/models/judge_model.gguf
LOCAL_JUDGE_WORKERS=1
PY_AGENT_LOCAL_JUDGE_IMAGE=zhixue-python-agent:local-judge

# Optional image names for local or registry builds.
APP_IMAGE=zhixue-java-app:local
PY_AGENT_IMAGE=zhixue-python-agent:local
FRONTEND_IMAGE=zhixue-frontend:local
