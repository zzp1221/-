# ί┐τώΑθίΙΘόΞλύν║ϊ╛Μ:
# ί╝ΑίΠΣόεθώ╗αϋχνϊ╜┐ύΦρ MiMo OpenAI ίΖ╝ίχ╣όΟξίΠμ:
#   ACTIVE_PROVIDER=openai_compatible
#   FALLBACK_PROVIDER=spark
#
# όψΦϋ╡δόεθίΙΘόΞλόαθύΒτ:
#   ACTIVE_PROVIDER=spark
#   FALLBACK_PROVIDER=openai_compatible
#
# όΚΑόεΚ Agent ίζΘώΑγϋ┐ΘώΑ╗ϋ╛ΣόρκίηΜίΡΞϋπμόηΡΎ╝Νϊ╕Ξί║Φίερϊ╗μύιΒϊ╕φύκυύ╝ΨύιΒίΖ╖ϊ╜ΥόρκίηΜίΡΞήΑΓ
# ύ╗Εϊ╗╢ύ║π LLM ϋοΗύδΨ:
#   ϋπΕίΙβ:
#   1. `__PROVIDER` ίΠψώΑΚΎ╝ΝόΦψόΝΒ `openai_compatible` / `spark`
#   2. `__MODEL` ίΠψίΗβώΑ╗ϋ╛ΣόρκίηΜίΡΞΎ╝ΝίοΓ `main_chat_model` / `fast_model` / `reasoning_model` / `safety_model`
#   3. `__MODEL` ϊ╣θίΠψύδ┤όΟξίΗβίΖ╖ϊ╜ΥόρκίηΜίΡΞ
#
# QUERY_REWRITE_LLM__PROVIDER=spark
# QUERY_REWRITE_LLM__MODEL=fast_model
# RETRIEVAL_LLM__PROVIDER=openai_compatible
# RETRIEVAL_LLM__MODEL=fast_model
# GENERATION_LLM__PROVIDER=openai_compatible
# GENERATION_LLM__MODEL=main_chat_model
# PRACTICE_LLM__PROVIDER=openai_compatible
# PRACTICE_LLM__MODEL=main_chat_model
# JUDGE_LLM__PROVIDER=spark
# JUDGE_LLM__MODEL=fast_model
# PROFILE_LLM__PROVIDER=openai_compatible
# PROFILE_LLM__MODEL=main_chat_model
# TUTOR_LLM__PROVIDER=openai_compatible
# TUTOR_LLM__MODEL=main_chat_model
# PLANNING_LLM__PROVIDER=spark
# PLANNING_LLM__MODEL=reasoning_model
# REVIEW_LLM__PROVIDER=openai_compatible
# REVIEW_LLM__MODEL=reasoning_model
# SAFETY_LLM__PROVIDER=openai_compatible
# SAFETY_LLM__MODEL=safety_model
# EVALUATION_LLM__PROVIDER=openai_compatible
# EVALUATION_LLM__MODEL=main_chat_model
# PATH_PLANNING_LLM__PROVIDER=openai_compatible
# PATH_PLANNING_LLM__MODEL=main_chat_model
